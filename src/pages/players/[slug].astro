---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPlayerSlugs, getPlayerProfile } from '../../lib/players/profile';

export async function getStaticPaths() {
	const slugs = await getAllPlayerSlugs();
	return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const profile = await getPlayerProfile(slug);

if (!profile) {
	return Astro.redirect('/404');
}
---

<BaseLayout title={profile.name}>
	<h1 class="text-2xl font-bold">{profile.name}</h1>
	{profile.hometown && <p class="text-ink-muted">{profile.hometown}</p>}
	{profile.bio && <p class="mt-3">{profile.bio}</p>}

	{
		profile.lawtonAppearances.length > 0 && (
			<section class="mt-8">
				<h2 class="mb-3 text-lg font-semibold">Lawton</h2>
				<div class="overflow-x-auto">
					<table>
						<thead>
							<tr>
								<th>Year</th>
								<th>Team</th>
								<th class="text-center">PPG</th>
								<th class="text-center">RPG</th>
								<th class="text-center">APG</th>
								<th class="text-center">Rings</th>
							</tr>
						</thead>
						<tbody>
							{profile.lawtonAppearances.map(({ year, stat }) => (
								<tr>
									<td>
										<a href={`/lawton/${year}/`}>{year}</a>
									</td>
									<td>{stat.team ?? '—'}</td>
									<td class="text-center">{stat.ppg !== undefined ? stat.ppg.toFixed(1) : '—'}</td>
									<td class="text-center">{stat.rpg ?? '—'}</td>
									<td class="text-center">{stat.apg ?? '—'}</td>
									<td class="text-center">{stat.rings}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>
		)
	}

	{
		(profile.boroughsHittingAppearances.length > 0 || profile.boroughsPitchingAppearances.length > 0) && (
			<section class="mt-8">
				<h2 class="mb-3 text-lg font-semibold">Boroughs</h2>
				{profile.boroughsHittingAppearances.length > 0 && (
					<div class="mb-4 overflow-x-auto">
						<table>
							<caption class="mb-2 text-left text-sm font-semibold text-ink-muted">Hitting</caption>
							<thead>
								<tr>
									<th>Year</th>
									<th>Region</th>
									<th class="text-center">AVG</th>
									<th class="text-center">OBP</th>
									<th class="text-center">HR</th>
								</tr>
							</thead>
							<tbody>
								{profile.boroughsHittingAppearances.map(({ year, region, stat }) => (
									<tr>
										<td>
											<a href={`/boroughs/${year}/`}>{year}</a>
										</td>
										<td>{region}</td>
										<td class="text-center">{stat.avg ?? '—'}</td>
										<td class="text-center">{stat.obp ?? '—'}</td>
										<td class="text-center">{stat.hr ?? '—'}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				)}
				{profile.boroughsPitchingAppearances.length > 0 && (
					<div class="overflow-x-auto">
						<table>
							<caption class="mb-2 text-left text-sm font-semibold text-ink-muted">Pitching</caption>
							<thead>
								<tr>
									<th>Year</th>
									<th>Region</th>
									<th class="text-center">ERA</th>
									<th class="text-center">WHIP</th>
									<th class="text-center">K</th>
								</tr>
							</thead>
							<tbody>
								{profile.boroughsPitchingAppearances.map(({ year, region, stat }) => (
									<tr>
										<td>
											<a href={`/boroughs/${year}/`}>{year}</a>
										</td>
										<td>{region}</td>
										<td class="text-center">{stat.era ?? '—'}</td>
										<td class="text-center">{stat.whip ?? '—'}</td>
										<td class="text-center">{stat.k ?? '—'}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				)}
			</section>
		)
	}

	{
		(profile.bgaSeasonAppearances.length > 0 || profile.bgaVenueAppearances.length > 0) && (
			<section class="mt-8">
				<h2 class="mb-3 text-lg font-semibold">BGA Tour</h2>
				{profile.bgaSeasonAppearances.length > 0 && (
					<div class="mb-4 overflow-x-auto">
						<table>
							<caption class="mb-2 text-left text-sm font-semibold text-ink-muted">Season rankings</caption>
							<thead>
								<tr>
									<th>Year</th>
									<th class="text-center">Rank</th>
									<th class="text-center">Avg</th>
								</tr>
							</thead>
							<tbody>
								{profile.bgaSeasonAppearances.map(({ year, ranking }) => (
									<tr>
										<td>
											<a href={`/bga-tour/${year}/`}>{year}</a>
										</td>
										<td class="text-center">{ranking.rank ?? '—'}</td>
										<td class="text-center">{ranking.avg ?? '—'}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				)}
				{profile.bgaVenueAppearances.length > 0 && (
					<div class="overflow-x-auto">
						<table>
							<caption class="mb-2 text-left text-sm font-semibold text-ink-muted">Venue results</caption>
							<thead>
								<tr>
									<th>Year</th>
									<th>Venue</th>
									<th class="text-center">Rank</th>
									<th class="text-center">Par</th>
								</tr>
							</thead>
							<tbody>
								{profile.bgaVenueAppearances.map(({ year, venue, venueSlug, result }) => (
									<tr>
										<td>{year}</td>
										<td>
											<a href={`/bga-tour/${year}/${venueSlug}/`}>{venue}</a>
										</td>
										<td class="text-center">{result.rank ?? '—'}</td>
										<td class="text-center">{result.par ?? '—'}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				)}
			</section>
		)
	}

	{
		profile.bowlAppearances.length > 0 && (
			<section class="mt-8">
				<h2 class="mb-3 text-lg font-semibold">Bonopio.com Bowl</h2>
				<ul class="list-inside list-disc">
					{profile.bowlAppearances.map((appearance) => (
						<li>
							<a href={`/bonopio-bowl/${appearance.edition.toLowerCase()}/`}>{appearance.title}</a>
							{appearance.wasPlayerOfTheGame && <span class="ml-2 text-sm font-semibold text-rank-gold">Player of the Game</span>}
						</li>
					))}
				</ul>
			</section>
		)
	}

	{
		profile.lawtonAppearances.length === 0 &&
			profile.boroughsHittingAppearances.length === 0 &&
			profile.boroughsPitchingAppearances.length === 0 &&
			profile.bgaSeasonAppearances.length === 0 &&
			profile.bowlAppearances.length === 0 && (
				<p class="mt-8 text-ink-muted">No recorded appearances yet.</p>
			)
	}
</BaseLayout>
