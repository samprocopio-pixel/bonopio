---
import BaseLayout from '../layouts/BaseLayout.astro';

const leagues = [
	{ name: 'Lawton', sport: 'Basketball', years: '2010–2015', href: '/lawton/' },
	{ name: 'Boroughs', sport: 'Baseball', years: '2002–2015', href: '/boroughs/' },
	{ name: 'BGA Tour', sport: 'Golf', years: '2008–2015', href: '/bga-tour/' },
	{ name: 'Bonopio.com Bowl', sport: 'Football', years: 'I · II · III', href: '/bonopio-bowl/' },
];
---

<BaseLayout title="Home">
	<section class="mb-12 text-center">
		<h1 class="text-4xl font-bold tracking-tight text-ink">Bonopio</h1>
		<p class="mt-3 text-lg text-ink-muted">we like sports and we don't care who knows.</p>
	</section>

	<section class="mb-12 grid gap-4 sm:grid-cols-2">
		{
			leagues.map((league) => (
				<a
					href={league.href}
					class="block rounded-lg border border-gray-200 p-5 no-underline transition hover:border-brand hover:shadow-sm"
				>
					<h2 class="text-lg font-semibold text-ink">{league.name}</h2>
					<p class="text-sm text-ink-muted">{league.sport}</p>
					<p class="mt-2 text-xs font-medium text-brand">{league.years}</p>
				</a>
			))
		}
	</section>
</BaseLayout>
