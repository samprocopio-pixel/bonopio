---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRankingBoards } from '../../lib/rankings';

const boards = await getRankingBoards();
---

<BaseLayout title="Rankings">
	<h1 class="mb-6 text-2xl font-bold">Rankings</h1>
	<div class="grid gap-4 sm:grid-cols-2">
		{
			boards.map((board) => (
				<a
					href={`/rankings/${board.slug}/`}
					class="block rounded-lg border border-gray-200 p-5 no-underline transition hover:border-brand hover:shadow-sm"
				>
					<h2 class="text-lg font-semibold text-ink">{board.title}</h2>
					<p class="mt-1 text-sm text-ink-muted">{board.description}</p>
				</a>
			))
		}
	</div>
</BaseLayout>
