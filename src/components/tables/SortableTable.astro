---
export interface Column {
	key: string;
	label: string;
	type?: 'number' | 'string';
	align?: 'left' | 'right' | 'center';
	defaultSort?: 'asc' | 'desc';
}

interface Props {
	columns: Column[];
	caption?: string;
	dense?: boolean;
	stickyColumns?: 2 | 3;
}

const { columns, caption, dense, stickyColumns } = Astro.props;

const captionId = caption ? `table-caption-${caption.replace(/\s+/g, '-').toLowerCase()}` : undefined;
---

{
	caption && (
		<p id={captionId} class="mb-2 text-left text-sm font-semibold text-ink-muted">
			{caption}
		</p>
	)
}
<div class="overflow-x-auto">
	<table
		data-sortable-table
		data-sticky-columns={stickyColumns || undefined}
		aria-labelledby={captionId}
		class:list={[dense && '[&_th]:px-2 [&_th]:py-1.5 [&_td]:px-2 [&_td]:py-1.5']}
	>
		<thead>
			<tr>
				{
					columns.map((c) => (
						<th
							scope="col"
							data-sort-key={c.key}
							data-sort-type={c.type ?? 'string'}
							data-default-sort={c.defaultSort}
							tabindex="0"
							role="button"
							aria-sort="none"
							class:list={[
								'sortable cursor-pointer select-none whitespace-nowrap hover:bg-gray-50',
								c.align === 'right' && 'text-right',
								c.align === 'center' && 'text-center',
							]}
						>
							{c.label}
							<span class="sort-indicator ml-1 inline-block w-2 text-ink-muted" aria-hidden="true" />
						</th>
					))
				}
			</tr>
		</thead>
		<tbody>
			<slot />
		</tbody>
	</table>
</div>

<style is:global>
	@layer base {
		table[data-sticky-columns='2'] thead th:nth-child(-n + 2),
		table[data-sticky-columns='2'] tbody td:nth-child(-n + 2),
		table[data-sticky-columns='3'] thead th:nth-child(-n + 3),
		table[data-sticky-columns='3'] tbody td:nth-child(-n + 3) {
			position: sticky;
			background: white;
		}

		/* earlier (more leftward) sticky columns always paint above later ones, so a subpixel
		   rounding overlap never hides an earlier column's content (e.g. the Rank sort arrow) */
		table[data-sticky-columns] thead th:nth-child(1),
		table[data-sticky-columns] tbody td:nth-child(1) {
			z-index: 3;
		}
		table[data-sticky-columns] thead th:nth-child(2),
		table[data-sticky-columns] tbody td:nth-child(2) {
			z-index: 2;
		}
		table[data-sticky-columns='3'] thead th:nth-child(3),
		table[data-sticky-columns='3'] tbody td:nth-child(3) {
			z-index: 1;
		}

		/* frozen-boundary shadow on the last sticky column, only when the table actually overflows */
		table[data-sticky-columns='2'][data-overflowing] thead th:nth-child(2),
		table[data-sticky-columns='2'][data-overflowing] tbody td:nth-child(2),
		table[data-sticky-columns='3'][data-overflowing] thead th:nth-child(3),
		table[data-sticky-columns='3'][data-overflowing] tbody td:nth-child(3) {
			box-shadow: 4px 0 6px -4px rgba(0, 0, 0, 0.3);
		}
	}
</style>

<script>
	function initSortableTables(root: ParentNode = document) {
		root.querySelectorAll<HTMLTableElement>('table[data-sortable-table]').forEach((table) => {
			if (table.dataset.sortableInit) return;
			table.dataset.sortableInit = 'true';

			const tbody = table.tBodies[0];
			if (!tbody) return;
			const headers = Array.from(table.querySelectorAll<HTMLTableCellElement>('thead th[data-sort-key]'));

			const cellFor = (row: HTMLTableRowElement, th: HTMLTableCellElement) =>
				row.cells[headers.indexOf(th)] as HTMLElement | undefined;

			const valueFor = (row: HTMLTableRowElement, th: HTMLTableCellElement, type: string) => {
				const cell = cellFor(row, th);
				const raw = cell?.dataset.sortValue ?? cell?.textContent?.trim() ?? '';
				return type === 'number' ? parseFloat(raw.replace(/[^0-9.-]/g, '')) || 0 : raw.toLowerCase();
			};

			const setIndicator = (th: HTMLTableCellElement, dir: 'asc' | 'desc' | null) => {
				headers.forEach((h) => {
					const indicator = h.querySelector('.sort-indicator');
					if (indicator) indicator.textContent = '';
				});
				if (!dir) return;
				const indicator = th.querySelector('.sort-indicator');
				if (indicator) indicator.textContent = dir === 'asc' ? '▲' : '▼';
			};

			const sortBy = (th: HTMLTableCellElement, dir: 'asc' | 'desc') => {
				const type = th.dataset.sortType ?? 'string';
				const rows = Array.from(tbody.rows);
				rows.sort((a, b) => {
					const va = valueFor(a, th, type);
					const vb = valueFor(b, th, type);
					const cmp = va < vb ? -1 : va > vb ? 1 : 0;
					return dir === 'asc' ? cmp : -cmp;
				});
				rows.forEach((r) => tbody.appendChild(r));
			};

			headers.forEach((th) => {
				const trigger = () => {
					const dir = th.getAttribute('aria-sort') === 'ascending' ? 'desc' : 'asc';
					headers.forEach((h) => h.setAttribute('aria-sort', 'none'));
					th.setAttribute('aria-sort', dir === 'asc' ? 'ascending' : 'descending');
					setIndicator(th, dir);
					sortBy(th, dir);
				};
				th.addEventListener('click', trigger);
				th.addEventListener('keydown', (e) => {
					if (e.key === 'Enter' || e.key === ' ') {
						e.preventDefault();
						trigger();
					}
				});
			});

			const def = headers.find((h) => h.dataset.defaultSort);
			if (def) (def as HTMLElement).click();
		});
	}

	function initStickyColumns(root: ParentNode = document) {
		root.querySelectorAll<HTMLTableElement>('table[data-sticky-columns]').forEach((table) => {
			if (table.dataset.stickyInit) return;
			table.dataset.stickyInit = 'true';

			const n = parseInt(table.dataset.stickyColumns ?? '0', 10);
			const headerRow = table.tHead?.rows[0];
			const wrapper = table.parentElement;
			if (!n || !headerRow || !wrapper) return;

			const measure = () => {
				let left = 0;
				for (let i = 0; i < n; i++) {
					const th = headerRow.cells[i] as HTMLElement | undefined;
					if (!th) continue;
					th.style.left = `${left}px`;
					table.tBodies[0]?.querySelectorAll<HTMLElement>(`tr > :nth-child(${i + 1})`).forEach((c) => {
						c.style.left = `${left}px`;
					});
					// round up so subpixel measurement never leaves the next sticky column
					// undershooting into this one (which would hide its content, e.g. the sort arrow)
					left += Math.ceil(th.getBoundingClientRect().width);
				}
				table.toggleAttribute('data-overflowing', wrapper.scrollWidth > wrapper.clientWidth);
			};

			measure();
			let resizeTimer: ReturnType<typeof setTimeout>;
			window.addEventListener('resize', () => {
				clearTimeout(resizeTimer);
				resizeTimer = setTimeout(measure, 150);
			});
		});
	}

	initSortableTables();
	initStickyColumns();
	document.addEventListener('astro:page-load', () => {
		initSortableTables();
		initStickyColumns();
	});
</script>
