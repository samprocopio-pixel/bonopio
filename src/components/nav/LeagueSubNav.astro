---
interface Item {
	label: string;
	href: string;
}

interface Props {
	items: Item[];
}

const { items } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav aria-label="Section" class="mb-6 border-b border-gray-200">
	<ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm font-medium">
		{
			items.map((item) => (
				<li>
					<a
						href={item.href}
						class:list={[
							'inline-block border-b-2 border-transparent px-1 pb-2 no-underline hover:border-brand',
							currentPath === item.href && 'border-brand text-brand',
						]}
					>
						{item.label}
					</a>
				</li>
			))
		}
	</ul>
</nav>
